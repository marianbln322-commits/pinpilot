# ============================================================
# PinPilot configuration
# Copy this file to ".env" and fill in your values.
# Everything below is OPTIONAL — the app runs without any keys
# (AI falls back to smart templates, and you can export CSV).
# ============================================================

# Port the app runs on
PORT=3000

# --- AI (Google Gemini) ---
# Free key from https://aistudio.google.com/app/apikey
# Without it, PinPilot uses a built-in template generator.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Public base URL for images (used in the Pinterest CSV export) ---
# Pinterest bulk upload needs PUBLIC image URLs. When testing locally
# leave this as the localhost URL; for real CSV upload set it to a
# public host that serves the /uploads folder (e.g. an ngrok URL, a
# server, or a CDN base). Example: https://your-domain.com
PUBLIC_BASE_URL=

# --- Pinterest API (Stage 2 — real publishing) ---
# Create an app at https://developers.pinterest.com/apps/
# You need STANDARD access to publish to real accounts.
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:3000/auth/pinterest/callback
# Use the sandbox while testing with Trial access:
# https://api-sandbox.pinterest.com/v5  (Trial)  |  https://api.pinterest.com/v5 (Standard)
PINTEREST_API_BASE=https://api.pinterest.com/v5
